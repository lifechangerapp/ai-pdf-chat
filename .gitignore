# Poetry
#   Similar to Pipenv, ~NOT RECOMMENDED~
#   for a Python library unless you're publishing
#   to the PyPI with Poetry.
poetry.lock
poetry.toml

# pdm
#   Similar to Pipenv, ~NOT RECOMMENDED~
#   for a Python library unless you're publishing
#   to the PyPI with PDM.
pdm.lock
.pdm.toml

